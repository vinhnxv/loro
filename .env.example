# Loro environment profile — copy to .env and adjust per machine.
# Loro reads these straight from the environment (no auto-dotenv); load with:
#   set -a && . ./.env && set +a
# Values shown are the defaults; uncomment a line to override it.

# --- TTS engine ---------------------------------------------------------
# Which TTS backend: soniox (cloud preset voices, default), gemini (cloud preset
# voices, batched), vieneu (on-device clone) or higgs (server clone).
# Overridable per run with --tts-engine.
# soniox does NOT clone the original speaker — it casts each diarized speaker
# to a fixed preset voice, so the dub no longer sounds like the speaker and TTS
# text leaves the machine for a per-use bill. --tts-engine vieneu restores
# on-device cloning. Multi-voice needs speaker labels, which only the
# assemblyai ASR engine provides; soniox + --asr-engine local renders the whole
# video in the single default voice.
# TTS_ENGINE=soniox

# Soniox (cloud; used only when TTS_ENGINE=soniox). The key is a credential —
# keep it here in the gitignored .env, never in a tracked file.
SONIOX_API_KEY=
# SONIOX_BASE_URL=https://tts-rt.soniox.com
# SONIOX_MODEL=tts-rt-v1
# SONIOX_LANGUAGE=vi
# SONIOX_SAMPLE_RATE=24000          # matches timeline_sr; emitted as WAV
# SONIOX_AUDIO_FORMAT=wav
# SONIOX_TIMEOUT=120                 # per synthesis call (seconds)
# Voice casting (28 preset voices: soniox.com/docs/tts/concepts/voices):
# SONIOX_DEFAULT_VOICE=Adrian        # single-speaker / no-diarization audio
# SONIOX_VOICE_POOL=Adrian,Maya,Noah,Nina,Jack,Emma   # rotated over speakers
# SONIOX_VOICE_MAP=A=Adrian,B=Maya   # pin specific diarized speakers to voices

# VieNeu-TTS (on-device clone; only when TTS_ENGINE=vieneu). Runs in an isolated venv:
#   pyenv virtualenv 3.14.5 vieneu && \
#   ~/.pyenv/versions/vieneu/bin/pip install vieneu
# VIENEU_PYTHON=~/.pyenv/versions/vieneu/bin/python
# VIENEU_MODEL=pnnbao-ump/VieNeu-TTS-v3-Turbo
# VIENEU_TEMPERATURE=0.8
# VIENEU_EMOTION=natural
# Cloning is audio-only by default; set to 1 to also feed the (English) ref_text.
# VIENEU_REF_TEXT=0

# Higgs Audio v3 (server clone; only needed when TTS_ENGINE=higgs).
# HIGGS_HOST=http://localhost:8000
# HIGGS_MODEL=bosonai/higgs-audio-v3-tts-4b

# Gemini (cloud preset voices; only when TTS_ENGINE=gemini). Like soniox it does
# NOT clone — it casts each diarized speaker to one of 30 prebuilt voices
# (multi-speaker is capped at 2 voices per call). The key is a credential — keep
# it here in the gitignored .env, never in a tracked file.
# DATA EGRESS: selecting gemini sends the Vietnamese dub text to Google's Gemini
# API, which retains it under Google's Generative AI terms — review those before
# using on sensitive/proprietary content.
GEMINI_API_KEY=
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# GEMINI_MODEL=gemini-3.1-flash-tts-preview   # or gemini-2.5-flash-preview-tts
# GEMINI_SAMPLE_RATE=24000          # fixed by the API; matches timeline_sr
# GEMINI_TIMEOUT=300                 # per synthesis call (seconds)
# Voice casting (30 preset voices: ai.google.dev/gemini-api/docs/speech-generation):
# GEMINI_DEFAULT_VOICE=Kore          # single-speaker / no-diarization audio
# GEMINI_VOICE_POOL=Kore,Puck,Aoede,Charon,Leda,Orus   # rotated over speakers
# GEMINI_VOICE_MAP=A=Kore,B=Puck     # pin specific diarized speakers to voices
# Call minimization (R4): gemini batches consecutive segments into ONE
# multi-speaker call, then splits the audio back per-segment — sharply cutting
# calls against Gemini's tight daily/RPM limits. Tune the batch bounds:
# GEMINI_BATCH_SEGMENTS=8            # max segments per call (1 = per-segment)
# GEMINI_BATCH_MAX_SYLLABLES=360     # ~84s ceiling on batch audio (drift guard)
# GEMINI_SPLIT_MIN_GAP_MS=200        # min inter-turn silence the splitter cuts on
# GEMINI_STYLE_PROMPT=               # optional tone/audio-tag directive

# --- Model serving (OpenAI-compatible: oMLX or llama.cpp), LLM_* namespace ---
# Loro is a pure client. Each role resolves a (host, api_key, model) endpoint:
# the base LLM_HOST/LLM_API_KEY/LLM_MODEL is the default; any LLM_*_<ROLE>
# override falls back to it. Roles:
#   VISION    = vision + seg_visual (image)
#   TRANSLATE = translate + context (text)
#   SEG       = sentence_seg (text)
#   AUDIO     = crosscheck re-listen + preflight probe (audio)
# Splitting a role onto its OWN host keeps each host on one resident model, so a
# one-model-resident router (remote llama.cpp) never pays a load/unload swap.
#
# Base endpoint (default for every role):
# LLM_HOST=http://127.0.0.1:1234/v1
# LLM_API_KEY=llm        # llama.cpp ignores this unless started with --api-key
# LLM_MODEL=gemma-4-12B-it-8bit
# LLM_TIMEOUT=180        # raise if a remote cold-load approaches the default
# LLM_IMAGE_MAX_BYTES=8388608  # per-image cap (8 MiB); oversized frame degrades, 0 disables
#
# Per-role overrides (unset -> inherit the base above):
# LLM_HOST_VISION=     LLM_API_KEY_VISION=     LLM_MODEL_VISION=
# LLM_HOST_TRANSLATE=  LLM_API_KEY_TRANSLATE=  LLM_MODEL_TRANSLATE=
# LLM_HOST_SEG=        LLM_API_KEY_SEG=        LLM_MODEL_SEG=
# LLM_HOST_AUDIO=      LLM_API_KEY_AUDIO=      LLM_MODEL_AUDIO=
#
# Profile A — split hosts (recommended for the remote router). Vision/translate/
# seg on the remote llama.cpp 26B (one resident model, no swap); audio on a
# separate always-hot oMLX 12B that hears audio. (On llama.cpp the audio model
# needs the mmproj build, e.g. the :UD-Q4_K_XL variant; thinking is auto-off.)
# LLM_HOST=http://100.x.x.x:8080/v1   # your remote router's host/IP
# LLM_MODEL=unsloth/gemma-4-26B-A4B-it-qat-GGUF:UD-Q4_K_XL
# LLM_HOST_AUDIO=http://127.0.0.1:1234/v1
# LLM_API_KEY_AUDIO=your-llama-key     # self-chosen, matches llama.cpp --api-key
# LLM_MODEL_AUDIO=gemma-4-12B-it-qat-8bit
#
# Profile B — single host (Apple Silicon oMLX): set only the base, leave
# overrides unset → every role uses one multimodal Gemma (no behavior change).
# LLM_HOST=http://127.0.0.1:1234/v1
# LLM_MODEL=gemma-4-12B-it-8bit

# --- ASR engine ---------------------------------------------------------
# Which ASR backend: soniox (cloud stt-async-v5, the new default), assemblyai
# (cloud universal-3-pro) or local (Nemotron windows + Granite/Gemma ensemble
# cross-check). Overridable per run with --asr-engine. A cloud engine sends ASR
# audio off-machine and bills per minute; the result is cached so a rerun of the
# same audio never re-uploads or re-pays. --asr-engine local is the zero-cost,
# fully-offline path for a fresh clone.
# ASR_ENGINE=soniox
#
# Soniox ASR (cloud; used only when ASR_ENGINE=soniox). REUSES the SONIOX_API_KEY
# above (shared with the Soniox TTS engine) — there is NO separate STT key. Note:
# rotating SONIOX_API_KEY affects both the STT and TTS engines; rotate between
# runs, not during one. Diarization is on by default and its speaker labels drive
# multi-voice output on a Soniox-TTS run (via voice_ref).
# SONIOX_STT_BASE_URL=https://api.soniox.com
# SONIOX_STT_MODEL=stt-async-v5         # v4 routes to v5 automatically after 2026-06-30
# SONIOX_STT_LANGUAGE_HINTS=en          # comma-separated, e.g. en,vi for mixed input
# SONIOX_STT_ENABLE_LANGUAGE_IDENTIFICATION=0   # on for mixed-language input
# SONIOX_STT_SPEAKER_DIARIZATION=1      # captured per word/segment; drives Soniox-TTS voices
# SONIOX_STT_CONTEXT_TERMS=             # comma-separated domain terms to bias (empty=off)
# SONIOX_STT_CONTEXT_TEXT=              # background text to bias (empty=off; ~8000-token cap)
# SONIOX_STT_CLEANUP=1                  # best-effort delete of uploaded file + transcription
# SONIOX_STT_POLL_INTERVAL=3.0
# SONIOX_STT_REQUEST_TIMEOUT=60.0       # per HTTP call
# SONIOX_STT_POLL_TIMEOUT_BASE=120.0    # poll budget = base + per_sec * audio_seconds
# SONIOX_STT_POLL_TIMEOUT_PER_SEC=2.0
#
# AssemblyAI (cloud; used only when ASR_ENGINE=assemblyai). The key is a
# credential — keep it here in the gitignored .env, never in a tracked file.
ASSEMBLYAI_API_KEY=
# ASSEMBLYAI_BASE_URL=https://api.assemblyai.com/v2
# ASSEMBLYAI_SPEECH_MODELS=universal-3-pro,universal-2   # primary,automatic-fallback
# ASSEMBLYAI_SPEAKER_LABELS=1        # diarization on (captured, not yet driving voices)
# ASSEMBLYAI_LANGUAGE_DETECTION=1    # auto-detect language...
# ASSEMBLYAI_LANGUAGE_CODE=          # ...or pin e.g. "en" (disables detection)
# ASSEMBLYAI_POLL_INTERVAL=3.0
# ASSEMBLYAI_REQUEST_TIMEOUT=60.0    # per HTTP call
# ASSEMBLYAI_POLL_TIMEOUT_BASE=120.0       # poll budget = base + per_sec * audio_seconds
# ASSEMBLYAI_POLL_TIMEOUT_PER_SEC=2.0

# --- Local ASR / cross-check workers (only for ASR_ENGINE=local) --------
# Isolated venvs; not needed when ASR_ENGINE=assemblyai.
# NEMOTRON_PYTHON=~/.pyenv/versions/nemo/bin/python
# GRANITE_PYTHON=~/.pyenv/versions/granite/bin/python
# GRANITE_MODEL_ID=ibm-granite/granite-speech-4.1-2b
